{
  "name": "signing-tool",
  "version": "1.2.0",
  "description": "Flare Systems Protocol uptime and rewards signing tool",
  "license": "MIT",
  "author": "Flare Network",
  "type": "module",
  "bin": {
    "signing-tool": "bin/signing-tool"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "scripts": {
    "build": "rimraf dist/ && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"lib/**/*.ts\" \"configs/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"lib/**/*.ts\" \"configs/**/*.ts\"",
    "sign": "tsx src/run.ts",
    "---------COMPILE---SCRIPTS": "",
    "compile": "hardhat compile",
    "test": "hardhat test",
    "test:coverage": "c8 pnpm test"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "chalk": "^4.0.0",
    "commander": "^9.4.1",
    "dotenv": "^17.0.0",
    "inquirer": "^12.11.1",
    "web3": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.1",
    "@flarenetwork/eslint-config-flare": "^0.0.1",
    "@flarenetwork/prettier-config-flare": "^0.0.2",
    "@nomicfoundation/hardhat-ethers": "^4.0.7",
    "@nomicfoundation/hardhat-ethers-chai-matchers": "^3.0.4",
    "@nomicfoundation/hardhat-mocha": "^3.0.15",
    "@openzeppelin/contracts": "5.0.2",
    "@types/mocha": "^10.0.0",
    "@types/node": "^22.7.5",
    "c8": "^11.0.0",
    "chai": "^5.3.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "ethers": "^6.14.0",
    "hardhat": "3.3.0",
    "mocha": "^11.7.5",
    "prettier": "^3.7.4",
    "prettier-plugin-solidity": "^2.3.1",
    "rimraf": "^3.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  },
  "prettier": "@flarenetwork/prettier-config-flare"
}
