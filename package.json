{
  "name": "signing-tool",
  "version": "1.1.0",
  "description": "Flare Systems Protocol uptime and rewards signing tool",
  "license": "MIT",
  "author": "Flare Network",
  "bin": {
    "signing-tool": "bin/signing-tool"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "scripts": {
    "build": "rimraf dist/ && tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint:check": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\" \"lib/**/*.ts\" \"configs/**/*.ts\"",
    "format:fix": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"lib/**/*.ts\" \"configs/**/*.ts\"",
    "sign": "ts-node src/sign.ts",
    "---------COMPILE---SCRIPTS": "",
    "compile": "hardhat compile",
    "c": "pnpm compile",
    "test": "hardhat test",
    "test:coverage": "nyc pnpm test"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "chalk": "^4.0.0",
    "commander": "^9.4.1",
    "dotenv": "^17.0.0",
    "inquirer": "^8.0.0",
    "web3": "^4.0.0"
  },
  "devDependencies": {
    "@eslint/compat": "^2.0.1",
    "@flarenetwork/eslint-config-flare": "^0.0.1",
    "@flarenetwork/prettier-config-flare": "^0.0.2",
    "@istanbuljs/nyc-config-typescript": "^1.0.2",
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.6",
    "@nomicfoundation/hardhat-web3-v4": "^1.0.0",
    "@openzeppelin/contracts": "5.0.2",
    "@typechain/ethers-v6": "^0.5.1",
    "@typechain/hardhat": "^9.1.0",
    "@types/chai": "^4.3.13",
    "@types/inquirer": "^8.0.0",
    "@types/lodash": "^4.14.186",
    "@types/mocha": "^10.0.0",
    "@types/node": "^16.11.15",
    "chai": "^4.3.7",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "ethers": "^6.14.0",
    "hardhat": "2.22.6",
    "mocha": "^10.0.0",
    "nyc": "^15.1.0",
    "prettier": "^3.7.4",
    "prettier-plugin-solidity": "^2.3.1",
    "rimraf": "^3.0.2",
    "ts-node": "^10.9.2",
    "typechain": "^8.3.2",
    "typescript": "^5.7.0"
  },
  "prettier": "@flarenetwork/prettier-config-flare",
  "nyc": {
    "extends": "@istanbuljs/nyc-config-typescript",
    "check-coverage": true,
    "all": true,
    "include": [
      "lib/initialize.ts",
      "lib/ECDSASignature.ts",
      "src/sign.ts",
      "src/status.ts",
      "configs/networks.ts"
    ],
    "reporter": [
      "html",
      "lcov",
      "text",
      "text-summary"
    ],
    "report-dir": "coverage"
  }
}
